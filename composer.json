{
    "name": "contenir/contenir-asset-laminas-mvc",
    "description": "Laminas MVC adapter for Contenir assets — keyed, profile-driven responsive image variants (incl. WebP/AVIF) backed by contenir/storage.",
    "type": "library",
    "license": "MIT",
    "version": "0.3.0",
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "contenir/storage": "^0.4.0",
        "laminas/laminas-cli": "^1.8",
        "laminas/laminas-http": "^2.0",
        "laminas/laminas-mvc": "^3.0",
        "laminas/laminas-router": "^3.0",
        "laminas/laminas-view": "^2.0",
        "psr/container": "^1.0 || ^2.0"
    },
    "require-dev": {
        "league/flysystem-memory": "^3.0",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Contenir\\Asset\\Laminas\\Mvc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Contenir\\Asset\\Laminas\\Mvc\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    },
    "extra": {
        "laminas": {
            "module": "Contenir\\Asset\\Laminas\\Mvc"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "laminas/laminas-component-installer": true
        }
    }
}
